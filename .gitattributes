# Normalize line endings: store text as LF in the repo, check out native on Windows.
* text=auto eol=lf

# Explicitly LF for code and config so CI (Linux) and local stay consistent.
*.py    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.txt   text eol=lf

# Treat these as binary (no diff/merge, no eol conversion).
*.docx  binary
*.png   binary
*.jpg   binary
*.ico   binary
